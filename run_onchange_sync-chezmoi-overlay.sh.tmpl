#!/bin/bash
{{ if not .isWork -}}
exit 0
{{ end -}}

# Re-runs whenever the overlay manifest changes (hash embedded below).
# On fresh install: deploys overlay files directly so a second chezmoi apply isn't needed.
# On manifest change: creates/removes symlinks and deploys new files.
# {{ include (joinPath .workRepoPath "chezmoi-overlay.map") | sha256sum }}

set -euo pipefail
script="${HOME}/.local/share/work-dotfiles/bin/sync-chezmoi-overlay.sh"
[[ -x "$script" ]] && exec "$script"
