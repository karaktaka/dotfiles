{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
{{- if .isWork }}
    "kn-internal-tools@kn-claude-plugins": true,
    "mr-summary@kn-claude-plugins": true,
{{- end }}
    "pr-review-toolkit@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
{{- if .isWork }}
    "rtk-hook@kn-claude-plugins": true,
{{- end }}
    "security-guidance@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
{{- if .isWork }}
  "env": {
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "eu.anthropic.claude-haiku-4-5-20251001-v1:0",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "eu.anthropic.claude-opus-4-6-v1",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "eu.anthropic.claude-sonnet-4-5-20250929-v1:0",
    "AWS_PROFILE": "dev",
    "AWS_REGION": "eu-central-1",
    "CLAUDE_CODE_PROXY_RESOLVES_HOSTS": "false",
    "CLAUDE_CODE_USE_BEDROCK": "true"
  },
  "model": "eu.anthropic.claude-opus-4-6-v1",
{{- end }}
  "outputStyle": "Explanatory",
  "permissions": {
    "allow": [
{{- if .isWork }}
      "WebFetch(domain:gitlab.example.com)",
      "Bash(aws *)",
      "Bash(az *)",
      "Bash(glab --version)",
      "Bash(glab auth status*)",
      "Bash(glab*list*)",
      "Bash(glab*view*)",
      "Bash(helm*lint*)",
      "Bash(helm*template*)",
      "Bash(jira epic*)",
      "Bash(jira issue list*)",
      "Bash(jira issue view*)",
      "Bash(jira sprint*)",
      "Bash(mark*--compile-only*)",
      "Bash(mark*--dry-run*)",
      "Bash(kubectl*describe*)",
      "Bash(kubectl*get*)",
      "Bash(kubectl*logs*)",
      "Bash(kubectl*version*)",
      "Bash(make tf/format *)",
      "Bash(terraform*fmt*)",
      "Bash(terraform*validate*)",
      "Read(~/.aws/config)",
      "Read(~/workspace/**)",
{{- end }}
      "Bash(awk *)",
      "Bash(basename *)",
      "Bash(cat *)",
      "Bash(column *)",
      "Bash(cut *)",
      "Bash(date *)",
      "Bash(diff *)",
      "Bash(dig *)",
      "Bash(dirname *)",
      "Bash(du *)",
      "Bash(echo *)",
      "Bash(file *)",
      "Bash(find *)",
      "Bash(git*branch*)",
      "Bash(git*commit*)",
      "Bash(git*diff*)",
      "Bash(git*fetch*)",
      "Bash(git*log*)",
      "Bash(git*ls*)",
      "Bash(git*remote*)",
      "Bash(git*rev-parse*)",
      "Bash(git*stash*)",
      "Bash(git*status*)",
      "Bash(git*switch*)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(hostname *)",
      "Bash(id *)",
      "Bash(jq *)",
      "Bash(less *)",
      "Bash(ls *)",
      "Bash(md5 *)",
      "Bash(more *)",
      "Bash(ping *)",
      "Bash(prettier *)",
      "Bash(pwd *)",
      "Bash(realpath *)",
      "Bash(ruff *)",
      "Bash(sed *)",
      "Bash(shasum *)",
      "Bash(shellcheck *)",
      "Bash(sort *)",
      "Bash(stat *)",
      "Bash(tail *)",
      "Bash(tr *)",
      "Bash(uname *)",
      "Bash(uniq *)",
      "Bash(uv *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(whoami *)",
      "Bash(yq *)",
      "Read(~/CLAUDE*)",
      "Read(~/.gitconfig)"
    ],
    "ask": [
      "Bash(curl *)",
      "Bash(git*add*)",
      "Bash(git*checkout*)",
      "Bash(git*push*)",
      "Bash(git*remote*add*)",
      "Bash(git*remote*remove*)",
      "Bash(git*remote*rename*)",
      "Bash(git*remote*set-url*)",
      "Bash(git*stash*drop*)",
      "Bash(rm *)",
      "Bash(awk* -i*inplace*)",
      "Bash(sed* -i*)",
      "Bash(yq* -i*)",
{{- if .isWork }}
      "Bash(aws*create*)",
      "Bash(aws*modify*)",
      "Bash(aws*put*)",
      "Bash(aws*run*)",
      "Bash(aws*start*)",
      "Bash(aws*stop*)",
      "Bash(aws*update*)",
      "Bash(aws s3 cp*)",
      "Bash(aws s3 mv*)",
      "Bash(aws s3 rm*)",
      "Bash(aws s3 sync*)",
      "Bash(glab*)",
      "Bash(jira issue comment*)",
      "Bash(jira issue create*)",
      "Bash(jira issue edit*)",
      "Bash(mark*)",
      "Bash(kubectl*cordon*)",
      "Bash(make apply-*)",
      "Bash(make destroy-*)",
      "Bash(make plan-*)",
      "Bash(make tf/*)",
{{- end }}
      "Bash(wget *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
{{- if .isWork }}
      "Bash(aws*delete*)",
      "Bash(aws*terminate*)",
      "Bash(kubectl*delete*)",
      "Bash(kubectl*drain*)",
      "Bash(kubectl*remove*)",
      "Bash(kubectl*rm*)",
      "Bash(kubectl*scale*)",
{{- end }}
      "Bash(find*-delete*)",
      "Bash(find*-exec*rm*)",
      "Bash(git*branch*-D*)",
      "Bash(git*stash*clear)"
    ]
  },
  "spinnerTipsEnabled": false,
  "statusLine": {
    "command": "/bin/bash ~/.claude/statusline-command.sh",
    "type": "command"
  }
}
