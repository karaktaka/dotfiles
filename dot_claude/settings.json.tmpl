{{- if .isWork -}}
{{ include (joinPath .workRepoPath "claude/settings.json") | replace "__HOME__" .chezmoi.homeDir -}}
{{ else -}}
{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {},
  "model": "opusplan",
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/allow-tmp-access.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/permissions-branch-check.sh"
          },
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/no-chezmoi-template-edit.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/permissions-branch-check.sh"
          },
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/no-chezmoi-template-edit.sh"
          },
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/no-plans-folder.sh"
          }
        ]
      },
      {
        "matcher": "NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/permissions-branch-check.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/permissions-read.sh"
          }
        ]
      },
      {
        "matcher": "Grep",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/permissions-read.sh"
          }
        ]
      },
      {
        "matcher": "Glob",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/permissions-read.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/permissions-bash-git.sh"
          },
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/permissions-bash-utils.sh"
          },
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/permissions-bash-dangerous.sh"
          },
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/permissions-bash-gh.sh"
          },
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/no-command-chaining.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "uv run ~/.claude/statusline-command.py"
  },
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "remember@claude-plugins-official": true
  },
  "outputStyle": "Explanatory",
  "spinnerTipsEnabled": false
}
{{ end -}}
