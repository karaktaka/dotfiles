# Custom aliases & abbreviations
# Generated by chezmoi - uses lookPath to detect available tools

# ─────────────────────────────────────────────────────────────────────────────
# Python / uv
# ─────────────────────────────────────────────────────────────────────────────
{{ if lookPath "uv" -}}
alias pip='uv pip'
alias venv='uv venv'
{{ end -}}

# ─────────────────────────────────────────────────────────────────────────────
# Container shortcuts (podman preferred)
# ─────────────────────────────────────────────────────────────────────────────
{{ if lookPath "podman" -}}
alias docker='podman'
abbr -a -g dps 'podman ps'
abbr -a -g dpsa 'podman ps -a'
abbr -a -g di 'podman images'
abbr -a -g drm 'podman rm'
abbr -a -g drmi 'podman rmi'
{{ end -}}
{{ if lookPath "podman-compose" -}}
abbr -a -g dc 'podman-compose'
abbr -a -g dcu 'podman-compose up -d'
abbr -a -g dcd 'podman-compose down'
abbr -a -g dcl 'podman-compose logs -f'
{{ end -}}

# ─────────────────────────────────────────────────────────────────────────────
# Fuzzy finder: fzf
# ─────────────────────────────────────────────────────────────────────────────
{{ if lookPath "fzf" -}}
{{ if lookPath "fd" -}}
set -gx FZF_DEFAULT_COMMAND 'fd --type f --hidden --follow --exclude .git'
set -gx FZF_CTRL_T_COMMAND $FZF_DEFAULT_COMMAND
{{ end -}}
{{ end -}}

# ─────────────────────────────────────────────────────────────────────────────
# Quick config editing
# ─────────────────────────────────────────────────────────────────────────────
abbr -a -g fishrc "$EDITOR ~/.config/fish/config.fish"
abbr -a -g reload 'source ~/.config/fish/config.fish'

# ─────────────────────────────────────────────────────────────────────────────
# Claude Code
# ─────────────────────────────────────────────────────────────────────────────
abbr -a -g claude-tokens 'npx ccusage@latest'
