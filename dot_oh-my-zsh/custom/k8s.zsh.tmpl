{{ if .isWork -}}
#!/usr/bin/env zsh
# Kubernetes helper functions - work-only module

# Extract cluster name from full context
function get_cluster_short() {
  echo "${1}" | sed 's:.*/::'
}

# Clean up stale kubeconfig entries
function cleanup_kubeconfig() {
  _k8s_bin=$(which kubectl)
  $_k8s_bin config-cleanup --raw > /tmp/cleaned_kubeconfig

  mv /tmp/cleaned_kubeconfig "${HOME}/.kube/config"
  chmod 600 "${HOME}/.kube/config"
}

# Update kubectl client to match cluster version
function update_kubectl() {
  echo "🔍 Checking for kubectl updates..."

  local aws_profile=prod
  local kube_context="arn:aws:eks:eu-central-1:REDACTED_PROD_ACCOUNT:cluster/apps-prod-cluster"

  local kubectl_version=$(AWS_PROFILE=${aws_profile} kubectl --context ${kube_context} version -o json 2>/dev/null)

  if [[ -z "$kubectl_version" ]]; then
    echo "⚠️  Could not connect to cluster to check version"
    return 1
  fi

  local kubectl_server_version=$(echo ${kubectl_version} | jq -r '.serverVersion.gitVersion' | grep -oE '[0-9]+\.[0-9]+\.[0-9]+')
  local kubectl_client_version=$(echo ${kubectl_version} | jq -r '.clientVersion.gitVersion' | grep -oE '[0-9]+\.[0-9]+\.[0-9]+')

  if [[ ! "${kubectl_server_version}" =~ [0-9]+\.[0-9]+\.[0-9]+ ]]; then
    echo "❌ Failed to parse server version from kubectl output"
    return 1
  fi

  if [[ "$kubectl_server_version" == "$kubectl_client_version" ]]; then
    echo "✅ kubectl is already up-to-date (version ${kubectl_client_version})"
  else
    echo "📥 Updating kubectl from ${kubectl_client_version} to ${kubectl_server_version}..."
    if curl -sL "https://dl.k8s.io/release/v${kubectl_server_version}/bin/darwin/arm64/kubectl" -o "${HOME}/.local/bin/kubectl"; then
      chmod +x "${HOME}/.local/bin/kubectl"
      echo "✅ kubectl updated to version ${kubectl_server_version}"
    else
      echo "❌ Failed to download kubectl ${kubectl_server_version}"
      return 1
    fi
  fi
}

# Adopt existing K8s resources into a Helm release
function helm-adopt-resources() {
  local release=$1
  local release_namespace=$2
  local values=$3
  shift
  shift
  shift

  if [[ -z "$release" || -z "$release_namespace" || -z "$values" ]]; then
    echo "Usage: helm-adopt-resources <release> <namespace> <values-file> [helm-args...]"
    return 1
  fi

  while read -r line; do
    local kind=$(<<<$line cut -d/ -f1)
    local nokind=$(<<<$line cut -d/ -f2)
    local namespace=$(<<<${nokind} rev | cut -d. -f1 | rev)
    local name=${nokind%$namespace}
    local name="${name%.}"

    kubectl annotate $kind $name ${namespace:+--namespace=$namespace} --overwrite meta.helm.sh/release-name=$release
    kubectl annotate $kind $name ${namespace:+--namespace=$namespace} --overwrite meta.helm.sh/release-namespace=$release_namespace
    kubectl label $kind $name ${namespace:+--namespace=$namespace} app.kubernetes.io/managed-by=Helm
  done <<< $(helm template $release -n $release_namespace -f $values $@ | kubectl grep -s)
}
{{ end -}}
