#!/usr/bin/env zsh
# Modern CLI aliases with tool detection fallbacks
# Generated by chezmoi - uses lookPath to detect available tools

# ─────────────────────────────────────────────────────────────────────────────
# File listing: eza > exa > ls
# ─────────────────────────────────────────────────────────────────────────────
{{ if lookPath "eza" -}}
alias ls='eza --icons'
alias ll='eza -la --icons --git'
alias lt='eza -la --icons --git --tree --level=2'
alias la='eza -a --icons'
{{ else if lookPath "exa" -}}
alias ls='exa --icons'
alias ll='exa -la --icons --git'
alias lt='exa -la --icons --git --tree --level=2'
alias la='exa -a --icons'
{{ else -}}
alias ll='ls -l'
alias la='ls -la'
{{ end -}}

# ─────────────────────────────────────────────────────────────────────────────
# File viewing: bat > cat
# ─────────────────────────────────────────────────────────────────────────────
{{ if lookPath "bat" -}}
alias cat='bat --paging=never'
alias catp='bat'  # with paging
{{ end -}}

# ─────────────────────────────────────────────────────────────────────────────
# Process viewing: procs > ps
# ─────────────────────────────────────────────────────────────────────────────
{{ if lookPath "procs" -}}
alias ps='procs'
{{ end -}}

# ─────────────────────────────────────────────────────────────────────────────
# Disk usage: dust > du
# ─────────────────────────────────────────────────────────────────────────────
{{ if lookPath "dust" -}}
alias du='dust'
{{ end -}}

# ─────────────────────────────────────────────────────────────────────────────
# Directory jumping: zoxide
# ─────────────────────────────────────────────────────────────────────────────
{{ if lookPath "zoxide" -}}
eval "$(zoxide init zsh)"
{{ end -}}

# ─────────────────────────────────────────────────────────────────────────────
# Fuzzy finder: fzf
# ─────────────────────────────────────────────────────────────────────────────
{{ if lookPath "fzf" -}}
# Use fd for fzf if available
{{ if lookPath "fd" -}}
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
{{ end -}}
{{ end -}}

# ─────────────────────────────────────────────────────────────────────────────
# Git shortcuts
# ─────────────────────────────────────────────────────────────────────────────
alias g='git'
alias gs='git status'
alias gd='git diff'
alias gds='git diff --staged'
alias ga='git add'
alias gc='git commit'
alias gca='git commit --amend'
alias gco='git checkout'
alias gb='git branch'
alias gl='git log --oneline -20'
alias glog='git log --graph --oneline --decorate --all'

# ─────────────────────────────────────────────────────────────────────────────
# Quick navigation
# ─────────────────────────────────────────────────────────────────────────────
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# ─────────────────────────────────────────────────────────────────────────────
# Python/uv
# ─────────────────────────────────────────────────────────────────────────────
{{ if lookPath "uv" -}}
alias pip='uv pip'
alias venv='uv venv'
{{ end -}}

# ─────────────────────────────────────────────────────────────────────────────
# Container shortcuts (podman preferred)
# ─────────────────────────────────────────────────────────────────────────────
{{ if lookPath "podman" -}}
alias docker='podman'
alias dps='podman ps'
alias dpsa='podman ps -a'
alias di='podman images'
alias drm='podman rm'
alias drmi='podman rmi'
{{ end -}}
{{ if lookPath "podman-compose" -}}
alias dc='podman-compose'
alias dcu='podman-compose up -d'
alias dcd='podman-compose down'
alias dcl='podman-compose logs -f'
{{ end -}}

# ─────────────────────────────────────────────────────────────────────────────
# Misc utilities
# ─────────────────────────────────────────────────────────────────────────────
{{ if lookPath "rg" -}}
alias grep='rg'
{{ end -}}

{{ if lookPath "fd" -}}
alias find='fd'
{{ end -}}

# Quick edit
alias zshrc='${EDITOR:-vim} ~/.zshrc'
alias reload='source ~/.zshrc'

# Safety nets
alias rm='rm -i'
alias cp='cp -i'
alias mv='mv -i'

# Human readable
alias df='df -h'
alias free='free -h 2>/dev/null || vm_stat'

# ─────────────────────────────────────────────────────────────────────────────
# Claude Code
# ─────────────────────────────────────────────────────────────────────────────
alias claude-tokens='npx ccusage@latest'
