{{- $isDarwin := eq .chezmoi.os "darwin" -}}
#!/usr/bin/env zsh
# Generic shell functions — universal

# ─────────────────────────────────────────────────────────────────────────────
# Universal Functions
# ─────────────────────────────────────────────────────────────────────────────

# Update system packages and tools
function update_system() {
  (( $+functions[update_kubectl] )) && update_kubectl
{{ if $isDarwin -}}
  brew update && \
  brew upgrade && \
{{ end -}}
  omz update
}
{{ if lookPath "ollama" }}
# Run Ollama with optimized settings
function ollama_run() {
  OLLAMA_FLASH_ATTENTION="1" OLLAMA_KV_CACHE_TYPE="q8_0" ollama serve
}
{{ end -}}
