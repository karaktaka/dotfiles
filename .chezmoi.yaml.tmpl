{{- $email := promptStringOnce . "email" "Email address" -}}
{{- $name := promptStringOnce . "name" "Name" -}}
{{- $isWork := promptBoolOnce . "isWork" "Is this a work machine?" -}}

encryption: "age"

age:
  identity: {{ joinPath .chezmoi.homeDir ".config/chezmoi/key.txt" | quote }}
  recipient: "age15j2c7ydy27fe32yku96aj7f2pse6zve4kdzhhw2pf7kzjjvj090shhafuv"

git:
  autoCommit: true
  autoPush: false

bitwarden:
  command: {{ .chezmoi.homeDir }}/.local/bin/bw-session

data:
  email: {{ $email | quote }}
  name: {{ $name | quote }}
  isWork: {{ $isWork }}
  signingKey: "91597F0387C6CED47F4CDAE0C43BCF28FD53157D"
{{- if $isWork }}
{{- $workRepoUrl := promptStringOnce . "workRepoUrl" "Work dotfiles repo URL" }}
  workRepoUrl: {{ $workRepoUrl | quote }}
  workRepoPath: {{ joinPath .chezmoi.homeDir ".local/share/work-dotfiles" | quote }}
{{- end }}
