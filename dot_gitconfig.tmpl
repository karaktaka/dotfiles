[user]
	name = {{ .name }}
	email = {{ .email }}
[commit]
	gpgsign = true
[pull]
	rebase = true
[stash]
	showPatch = true
	showStat = false
{{ if eq .chezmoi.os "darwin" -}}
[credential]
	helper = store
{{ end -}}
[rerere]
	enabled = true
[branch]
	autosetuprebase = always
[includeIf "gitdir:~/workspace/"]
	path = ~/.gitconfig-work
[includeIf "gitdir:~/personal/"]
	path = ~/.gitconfig-personal
