[user]
	name = {{ .name }}
	email = {{ .email }}
	signingkey = {{ .signingKey }}
[commit]
	gpgsign = true
[pull]
	rebase = true
[stash]
	showPatch = true
	showStat = false
{{ if eq .chezmoi.os "darwin" -}}
[credential]
	helper = store
{{ end -}}
[rerere]
	enabled = true
[branch]
	autosetuprebase = always
[include]
	path = ~/.gitconfig.d/work

